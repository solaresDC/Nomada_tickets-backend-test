# =============================================================
# NOMADA TICKETS — API TEST FILE
# =============================================================
#
# BEFORE YOU START — READ THIS ONCE
# ──────────────────────────────────
# This file tests your entire backend from health check to door scan.
# Each step produces a value you paste into the next step.
#
# THE VALUE CHAIN:
#   Step 3 (terminal) → gives you a paymentIntentId (pi_...)
#   Step 5 (GET tickets) → gives you a qrToken
#   Step 6 (auth) → gives you a bearer token
#   Steps 7, 8, 9, 10 → use bearer token + qrToken
#
# HOW TO RUN A TEST:
#   Click "Send Request" that appears above any line starting with ###
#
# REQUIREMENT:
#   VS Code extension "REST Client" must be installed
#   (search "REST Client" by Huachao Mao in the Extensions panel)
#
# =============================================================




# ┌─────────────────────────────────────────────────────────┐
# │  STEP 1 — HEALTH CHECK                                  │
# │  Purpose: confirm the server is running before anything │
# │  Expected response: { "status": "ok" }                  │
# │  If you get an error: run  npm run dev  in terminal 1   │
# └─────────────────────────────────────────────────────────┘

### Step 1 — Health Check
GET http://localhost:3000/health




# ┌─────────────────────────────────────────────────────────┐
# │  STEP 2 — CREATE A PAYMENT INTENT                       │
# │  Purpose: simulate a buyer choosing tickets             │
# │                                                         │
# │  ⚠️  NOTE: The paymentIntentId you get here is NOT used │
# │  in steps 4/5. Steps 4/5 use the ID from the TERMINAL   │
# │  after you run stripe trigger in Step 3.                │
# │  (They are two separate IDs — see reference guide)      │
# │                                                         │
# │  Expected response:                                     │
# │    { clientSecret, paymentIntentId, pricing }           │
# └─────────────────────────────────────────────────────────┘

### Step 2a — Create Payment Intent (valid: 2 female + 1 male)
# 📋 PLACEHOLDER — update after each run:
# Last paymentIntentId: pi_3T7KTZGV3cwb7LAj1eZmrjTq
POST http://localhost:3000/api/checkout/create-intent
Content-Type: application/json

{
  "femaleQty": 2,
  "maleQty": 1,
  "language": "en"
}

###

### Step 2b — Should FAIL: both quantities are zero (expect 400 error)
POST http://localhost:3000/api/checkout/create-intent
Content-Type: application/json

{
  "femaleQty": 0,
  "maleQty": 0,
  "language": "en"
}

###

### Step 2c — Should FAIL: negative quantity (expect 400 error)
POST http://localhost:3000/api/checkout/create-intent
Content-Type: application/json

{
  "femaleQty": -1,
  "maleQty": 1,
  "language": "en"
}




# ┌─────────────────────────────────────────────────────────┐
# │  STEP 3 — FIRE THE WEBHOOK  ← TERMINAL COMMAND          │
# │  Purpose: simulate a completed payment                  │
# │                                                         │
# │  This cannot be done from this file.                    │
# │  Run these commands in your terminals:                  │
# │                                                         │
# │  TERMINAL 1 (already running):                          │
# │    npm run dev                                          │
# │                                                         │
# │  TERMINAL 2 — start Stripe listener:                    │
# │    stripe listen --forward-to localhost:3000/api/webhooks/stripe
# │    → Copy the  whsec_...  value into your .env file     │
# │      as STRIPE_WEBHOOK_SECRET                           │
# │                                                         │
# │  TERMINAL 3 — trigger the payment (WITH metadata):      |
# │   the command below is a single line delete the \       |
# |                                                         │ 
# │    stripe trigger payment_intent.succeeded \            │
# │      --override payment_intent:metadata.femaleQty=2 \   │
# │      --override payment_intent:metadata.maleQty=1       │
# | Optional                                                |
# |     --override payment_intent:amount=432 \              │ 
# |     --override payment_intent:currency=cad              |
# |                                                         |
# │                                                         │
# │  ⚠️  ALWAYS use the --override flags above.             │
# │  Without them, femaleQty and maleQty default to 0       │
# │  and zero tickets will be created.                      │
# │                                                         │
# │  ✅ WHAT TO LOOK FOR in Terminal 1 after triggering:    │
# │    ════════════════════════════════════════════════     │
# │    [Webhook] ✅ payment_intent.succeeded                │
# │    [Webhook]    ID: pi_XXXXXXXXXXXXXXXX   ← COPY THIS   │
# │    [Webhook]    Quantities → female: 2, male: 1         │
# │    [Webhook]    Order saved ✓                           │
# │    [Webhook]    Individual tickets created: 3 ✓         │
# │    ════════════════════════════════════════════════     │
# │                                                         │
# │  Copy the  pi_XXXXXXXXXXXXXXXX  ID from your logs.      │
# │  Paste it into Steps 4 and 5 below.                     │
# └─────────────────────────────────────────────────────────┘




# ┌─────────────────────────────────────────────────────────┐
# │  STEP 4 — CHECK ORDER (legacy single-QR endpoint)       │
# │  Purpose: confirm the order was saved after webhook     │
# │                                                         │
# │  Replace the pi_... ID below with the one from          │
# │  your Terminal 1 logs in Step 3.                        │
# │                                                         │
# │  Before webhook fires: { "status": "pending" }          │
# │  After webhook fires:  { "status": "ready", "qrToken":  │
# │                           ..., "qrImageDataUrl": ... }  │
# └─────────────────────────────────────────────────────────┘

### Step 4 — Get Order QR
# 📋 PLACEHOLDER — paste the pi_... ID from Terminal 1 logs:
# Last ID used: pi_3T7MfxGV3cwb7LAj26hFx57g
# EXAMPLE: GET http://localhost:3000/api/orders/pi_REPLACE_WITH_YOUR_PAYMENT_INTENT_ID/qr
GET http://localhost:3000/api/orders/pi_3T7MfxGV3cwb7LAj26hFx57g/qr




# ┌─────────────────────────────────────────────────────────┐
# │  STEP 5 — GET INDIVIDUAL TICKETS (new endpoint)         │
# │  Purpose: get all per-person QR codes for this order    │
# │                                                         │
# │  Use the SAME pi_... ID as Step 4.                      │
# │                                                         │
# │  Before webhook fires: { "status": "pending" }          │
# │  After webhook fires:                                   │
# │    {                                                    │
# │      "status": "ready",                                 │
# │      "tickets": [                                       │
# │        { "id": "...", "ticketType": "female",           │
# │          "qrToken": "abc123...",  ← COPY ONE OF THESE  │
# │          "qrImageDataUrl": "..." },                     │
# │        ...                                              │
# │      ]                                                  │
# │    }                                                    │
# │                                                         │
# │  Copy one qrToken value — you need it in Steps 8 and 9 │
# └─────────────────────────────────────────────────────────┘

### Step 5 — Get Individual Tickets
# 📋 PLACEHOLDER — same pi_... ID as Step 4:
# Last ID used: pi_3T7MfxGV3cwb7LAj26hFx57g
# EXAMPLE: GET http://localhost:3000/api/orders/pi_REPLACE_WITH_YOUR_PAYMENT_INTENT_ID/qr
GET http://localhost:3000/api/orders/pi_3T7MfxGV3cwb7LAj26hFx57g/tickets




# ┌─────────────────────────────────────────────────────────┐
# │  STEP 6 — SCANNER LOGIN (get your bearer token)         │
# │  Purpose: authenticate as a door scanner                │
# │                                                         │
# │  The PIN is set in your .env file as SCANNER_PIN        │
# │  Default is 1234.                                       │
# │                                                         │
# │  After sending the correct PIN:                         │
# │  Copy the "token" value from the response.              │
# │  You will paste it into Steps 7, 8, 9, 10.             │
# │                                                         │
# │  ✅ Correct PIN → { "token": "long-hex...", "expiresAt" }│
# │  ❌ Wrong PIN   → { "error": "Incorrect PIN." } (401)   │
# └─────────────────────────────────────────────────────────┘

### Step 6a — Scanner Auth (correct PIN — copy the token from response!)
# 📋 PLACEHOLDER — paste the token into steps 7-10:
# Last token: 6cecc2dd9e857f679d44d0d921c7326a3d3e6e488911a57bdad0b59bb9762b3f
POST http://localhost:3000/api/scanner/auth
Content-Type: application/json

{
  "pin": "1234"
}

###

### Step 6b — Scanner Auth (wrong PIN — should return 401)
POST http://localhost:3000/api/scanner/auth
Content-Type: application/json

{
  "pin": "0000"
}




# ┌─────────────────────────────────────────────────────────┐
# │  STEP 7 — FETCH ALL VALID TICKETS (scanner bulk load)   │
# │  Purpose: see what the scanner app loads on startup     │
# │                                                         │
# │  Replace the token below with yours from Step 6.        │
# │                                                         │
# │  Expected: { "tickets": [...], "count": 3,              │
# │              "fetchedAt": "..." }                       │
# └─────────────────────────────────────────────────────────┘

### Step 7 — Get All Valid Tickets
# 📋 PLACEHOLDER — paste your bearer token from Step 6:
# Last token: 6cecc2dd9e857f679d44d0d921c7326a3d3e6e488911a57bdad0b59bb9762b3f
GET http://localhost:3000/api/scanner/tickets
Authorization: Bearer 6cecc2dd9e857f679d44d0d921c7326a3d3e6e488911a57bdad0b59bb9762b3f




# ┌─────────────────────────────────────────────────────────┐
# │  STEP 8 — SCAN A TICKET (first scan)                    │
# │  Purpose: simulate the scanner reading a QR code        │
# │                                                         │
# │  Replace the bearer token with yours from Step 6.       │
# │  Replace the qrToken with one from the Step 5 response. │
# │                                                         │
# │  ✅ Expected: { "result": "accepted",                   │
# │                 "ticketType": "female" or "male" }      │
# └─────────────────────────────────────────────────────────┘

### Step 8 — Scan a Ticket (first scan — should be ACCEPTED)
# 📋 PLACEHOLDER — paste bearer token + qrToken:
# Last token: 6cecc2dd9e857f679d44d0d921c7326a3d3e6e488911a57bdad0b59bb9762b3f
POST http://localhost:3000/api/scanner/scan
Authorization: Bearer 6cecc2dd9e857f679d44d0d921c7326a3d3e6e488911a57bdad0b59bb9762b3f
Content-Type: application/json

{
  //"qrToken": "PASTE_QR_TOKEN_FROM_STEP_5"
  "qrToken": "eb6e9cd67d4043f65a17f890c05e97395f64a57125d69d5ad2a616c085f03f49"
}




# ┌─────────────────────────────────────────────────────────┐
# │  STEP 9 — SCAN THE SAME TICKET AGAIN                    │
# │  Purpose: prove that duplicate scans are rejected       │
# │                                                         │
# │  Use the exact same qrToken as Step 8.                  │
# │                                                         │
# │  ✅ Expected: { "result": "rejected",                   │
# │                 "message": "Already Scanned" }          │
# └─────────────────────────────────────────────────────────┘

### Step 9 — Scan Same Ticket Again (should be REJECTED)
# 📋 PLACEHOLDER — same bearer token and qrToken as Step 8:
# Last token: 6cecc2dd9e857f679d44d0d921c7326a3d3e6e488911a57bdad0b59bb9762b3f
POST http://localhost:3000/api/scanner/scan
Authorization: Bearer PASTE_BEARER_TOKEN_FROM_STEP_6
Content-Type: application/json

{
  "qrToken": "PASTE_SAME_QR_TOKEN_AS_STEP_8"
}




# ┌─────────────────────────────────────────────────────────┐
# │  STEP 10 — VERIFY TICKET COUNT DROPPED                  │
# │  Purpose: confirm the scanned ticket is now gone        │
# │           from the valid pool                           │
# │                                                         │
# │  If Step 3 created 3 tickets and you scanned 1,         │
# │  this should now return count: 2                        │
# └─────────────────────────────────────────────────────────┘

### Step 10 — Get Valid Tickets Again (count should have dropped by 1)
# 📋 PLACEHOLDER — paste your bearer token from Step 6:
GET http://localhost:3000/api/scanner/tickets
Authorization: Bearer PASTE_BEARER_TOKEN_FROM_STEP_6




